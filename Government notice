// file: components/NoticeBoard.tsx
'use client';

import React, { useState } from 'react';

interface Notice {
  id: string;
  title: string;
  pdfUrl: string;
  category: string;
  isPinned: boolean;
  isCancelled: boolean;
  createdAt: string;
}

export default function NoticeBoard({ initialNotices }: { initialNotices: Notice[] }) {
  const [notices, setNotices] = useState<Notice[]>(initialNotices);
  const [searchTerm, setSearchTerm] = useState('');
  const [categoryFilter, setCategoryFilter] = useState('ALL');
  const [viewingPdf, setViewingPdf] = useState<string | null>(null);

  const filteredNotices = notices.filter((notice) => {
    const matchesSearch = notice.title.toLowerCase().includes(searchTerm.toLowerCase());
    const matchesCat = categoryFilter === 'ALL' || notice.category === categoryFilter;
    return matchesSearch && matchesCat;
  });

  return (
    <div className="bg-white border border-slate-300 rounded shadow-md overflow-hidden max-w-5xl mx-auto my-6">
      {/* Banner */}
      <div className="bg-goiBlue p-4 border-b-2 border-goiGold flex justify-between items-center text-white">
        <div>
          <h2 className="text-base font-bold tracking-wide">OFFICIAL NOTICE BOARD & CIRCULARS</h2>
          <p className="text-[10px] text-goiGold font-semibold">North East Hospitality Council Records Center</p>
        </div>
        <span className="text-[10px] bg-red-600 px-2 py-0.5 rounded font-mono font-bold animate-pulse">LATEST UPDATES</span>
      </div>

      {/* Control Box */}
      <div className="p-4 bg-slate-50 border-b border-slate-200 flex flex-col md:flex-row gap-4 items-center justify-between">
        <input
          type="text"
          placeholder="Search by Circular Title..."
          value={searchTerm}
          onChange={(e) => setSearchTerm(e.target.value)}
          className="w-full md:w-64 px-3 py-1.5 border border-slate-300 rounded text-xs focus:ring-1 focus:ring-goiBlue outline-none"
        />
        <div className="flex gap-2 w-full md:w-auto overflow-x-auto">
          {['ALL', 'GENERAL', 'CIRCULAR', 'EVENT', 'SCHOLARSHIP'].map((cat) => (
            <button
              key={cat}
              onClick={() => setCategoryFilter(cat)}
              className={`px-3 py-1 rounded text-[11px] font-bold whitespace-nowrap transition ${
                categoryFilter === cat ? 'bg-goiBlue text-white' : 'bg-white text-slate-600 border border-slate-300 hover:bg-slate-100'
              }`}
            >
              {cat}
            </button>
          ))}
        </div>
      </div>

      {/* Notice Table Layout */}
      <div className="overflow-x-auto">
        <table className="w-full text-left text-xs border-collapse">
          <thead>
            <tr className="bg-slate-100 border-b border-slate-200 text-slate-700 font-bold uppercase">
              <th className="p-3">Reference Date</th>
              <th className="p-3">Category</th>
              <th className="p-3">Circular Title</th>
              <th className="p-3 text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            {filteredNotices.length > 0 ? (
              filteredNotices.map((notice) => (
                <tr key={notice.id} className="border-b border-slate-100 hover:bg-slate-50 transition relative">
                  <td className="p-3 text-slate-500 font-mono">
                    {new Date(notice.createdAt).toLocaleDateString('en-IN', {
                      day: '2-digit',
                      month: 'short',
                      year: 'numeric',
                    })}
                  </td>
                  <td className="p-3">
                    <span className="px-2 py-0.5 rounded bg-slate-200 text-slate-800 text-[9px] font-bold">
                      {notice.category}
                    </span>
                  </td>
                  <td className="p-3 font-medium text-slate-800 relative flex items-center gap-2">
                    {notice.isPinned && (
                      <span className="bg-amber-100 text-amber-800 border border-amber-300 text-[8px] font-extrabold px-1.5 py-0.2 rounded">
                        PINNED
                      </span>
                    )}
                    <span className={notice.isCancelled ? 'line-through text-slate-400' : ''}>
                      {notice.title}
                    </span>
                    {notice.isCancelled && (
                      <span className="ml-2 border border-red-500 text-red-500 text-[8px] font-extrabold px-1 rounded transform rotate-3 inline-block">
                        CANCELLED
                      </span>
                    )}
                  </td>
                  <td className="p-3 text-right whitespace-nowrap">
                    <button
                      onClick={() => setViewingPdf(notice.pdfUrl)}
                      className="px-2 py-1 bg-goiBlue text-white rounded text-[10px] font-bold hover:bg-goiBlue-light mr-1 inline-flex items-center gap-1"
                    >
                      📄 View
                    </button>
                    <a
                      href={notice.pdfUrl}
                      download
                      className="px-2 py-1 bg-slate-200 text-slate-700 rounded text-[10px] font-bold hover:bg-slate-300"
                    >
                      ↓ Download
                    </a>
                  </td>
                </tr>
              ))
            ) : (
              <tr>
                <td colSpan={4} className="p-8 text-center text-slate-400 italic">
                  No notifications matching selected filters.
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>

      {/* Built-in PDF Modal Window */}
      {viewingPdf && (
        <div className="fixed inset-0 bg-black/60 flex items-center justify-center p-4 z-50 animate-fade-in">
          <div className="bg-white rounded shadow-2xl max-w-4xl w-full h-[85vh] flex flex-col overflow-hidden border-2 border-goiBlue">
            <div className="bg-goiBlue text-white p-3 flex justify-between items-center">
              <span className="font-bold text-xs tracking-wider">NEHC OFFICIAL PORTAL DOCUMENT VIEWER</span>
              <button
                onClick={() => setViewingPdf(null)}
                className="bg-red-700 text-white rounded px-3 py-1 font-bold text-xs hover:bg-red-600"
              >
                CLOSE [X]
              </button>
            </div>
            <div className="flex-grow bg-slate-700 relative">
              {/* Fallback mock visualization layer if real PDFs are blocked */}
              <iframe
                src={`https://docs.google.com/gview?url=${viewingPdf}&embedded=true`}
                className="w-full h-full border-none"
                title="Document Reader"
              ></iframe>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
